@startuml
' Диаграмма классов симулятора пиццерии

package "Домен" {
  class "Пиццерия (Pizzeria)" as Pizzeria {
    +kitchen: Kitchen
    +hall: Hall
    +order_counter: OrderCounter
    +delivery: DeliveryCoordinator
    +employees: list[Employee]
    +orders: list[Order]
    +revenue: float
  }

  class "Заказ (Order)" as Order {
    +id: int
    +status: OrderStatus
    +customer_type: CustomerType
    +payment_type: PaymentType
    +is_paid: bool
    +total_price: float
  }

  class "Пицца (Pizza)" as Pizza {
    +id: int
    +name: str
    +size: PizzaSize
    +status: PizzaStatus
    +price: float
  }

  class "Кухня (Kitchen)" as Kitchen {
    +ovens: list[Oven]
    +stock: Stock
  }

  class "Печь (Oven)" as Oven {
    +id: int
    +capacity: int
    +is_operational: bool
    +baking: list[BakingTask]
    +queue: list[BakingTask]
  }

  class "Склад (Stock)" as Stock {
    +ingredients: dict[str, float]
    +pizza_boxes: int
    +receipt_paper_rolls: int
  }

  class "Зал (Hall)" as Hall {
    +tables: list[Table]
  }

  class "Столик (Table)" as Table {
    +number: int
    +capacity: int
    +is_occupied: bool
    +order_id: int?
  }

  class "Стойка заказов (OrderCounter)" as OrderCounter {
    +menu: Menu
    +payment_system: PaymentSystem
  }

  class "Меню (Menu)" as Menu {
    +items: dict[int, MenuItem]
  }

  class "Оплата (PaymentSystem)" as PaymentSystem {
    +card_terminal: CardTerminal
    +cash_desk: CashDesk
  }

  class "Доставка (DeliveryCoordinator)" as DeliveryCoordinator {
    +tasks: dict[int, DeliveryTask]
  }

  class "Сотрудник (Employee)" as Employee {
    +id: int
    +name: str
    +role: EmployeeRole
    +salary: float
    +active: bool
  }

  class Cook
  class Courier
  class Cashier
  class Manager
}

package "Прикладной слой" {
  class PizzeriaService
}

package "Инфраструктура" {
  class JsonStateRepository
}

package "Интерфейс" {
  class CliApp
}

Pizzeria *-- Kitchen
Pizzeria *-- Hall
Pizzeria *-- OrderCounter
Pizzeria *-- DeliveryCoordinator
Pizzeria *-- "много" Order
Pizzeria *-- "много" Employee

Order *-- "много" Pizza
Kitchen *-- "много" Oven
Kitchen *-- Stock
Hall *-- "много" Table
OrderCounter *-- Menu
OrderCounter *-- PaymentSystem
PaymentSystem *-- CardTerminal
PaymentSystem *-- CashDesk
DeliveryCoordinator *-- "много" DeliveryTask

Cook --|> Employee
Courier --|> Employee
Cashier --|> Employee
Manager --|> Employee

PizzeriaService --> Pizzeria
JsonStateRepository --> Pizzeria
CliApp --> PizzeriaService
@enduml
