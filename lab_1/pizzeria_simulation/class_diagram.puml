@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false

' ==================== ДОМЕН ====================

class Пицца {
    -id: Integer
    -название: String
    -размер: String
    -топпинги: List<String>
    -требования_к_ингредиентам: Map<String, Float>
    -базовая_цена: Float
    -статус: String
    -оставшееся_время_готовки: Integer
    +цена: Float
    +начать_подготовку(): void
    +начать_выпечку(минуты: Integer): void
    +готово(): void
}

class Пункт_меню {
    -id: Integer
    -название: String
    -категория: String
    -цена: Float
    -топпинги: List<String>
    -требования_к_ингредиентам: Map<String, Float>
    -доступен: Boolean
}

class Меню {
    -элементы: Map<Integer, Пункт_меню>
    +получить_элемент(id: Integer): Пункт_меню
    +список_пицц(): List<Пункт_меню>
    +список_напитков(): List<Пункт_меню>
}

class Заказ {
    -id: Integer
    -пиццы: List<Пицца>
    -напитки: List<Пункт_меню>
    -статус: String
    -тип_клиента: String
    -номер_стола: Integer
    -адрес_доставки: String
    -телефон: String
    -тип_оплаты: String
    -общая_цена: Float
    -время_создания: String
    -повар: Integer
    -курьер: Integer
    -оплачен: Boolean
    -процент_чаевых: Integer
    -сумма_чаевых: Float
    -оплаченная_сумма: Float
    +подтвердить(): void
    +начать_готовку(): void
    +начать_выпечку(): void
    +готов(): void
    +отправить_на_доставку(): void
    +завершить(): void
    +отменить(): void
    +пересчитать_итог(): Float
}

class Клиент {
    -id: Integer
    -тип: String
}

class Клиент_в_зале {
    -номер_стола: Integer
    -количество_гостей: Integer
}

class Клиент_с_доставкой {
    -адрес: String
    -телефон: String
}

Клиент <|-- Клиент_в_зале
Клиент <|-- Клиент_с_доставкой

class Сотрудник {
    -id: Integer
    -имя: String
    -роль: String
    -зарплата: Float
    -активен: Boolean
}

class Повар
class Курьер
class Кассир
class Менеджер

Сотрудник <|-- Повар
Сотрудник <|-- Курьер
Сотрудник <|-- Кассир
Сотрудник <|-- Менеджер

class Стол {
    -номер: Integer
    -вместимость: Integer
    -занят: Boolean
    -id_заказа: Integer
    +занять(id_заказа: Integer): void
    +освободить(): void
}

class Зал {
    -столы: List<Стол>
    +найти_стол(номер: Integer): Стол
    +найти_свободный_стол(гостей: Integer): Стол
}

class Склад {
    -ингредиенты: Map<String, Float>
    -коробки_для_пиццы: Integer
    -рулоны_чеков: Integer
    +есть_ингредиенты(нужно: Map<String, Float>): Boolean
    +использовать_ингредиенты(нужно: Map<String, Float>): void
}

class Задача_выпечки {
    -id_пиццы: Integer
    -оставшееся_время: Integer
}

class Печь {
    -id: Integer
    -вместимость: Integer
    -работает: Boolean
    -выпекается: List<Задача_выпечки>
    -очередь: List<Задача_выпечки>
    +добавить_в_очередь(id_пиццы: Integer, минуты: Integer): void
    +тик(минуты: Integer): List<Integer>
}

class Кухня {
    -печи: List<Печь>
    -склад: Склад
    -вместимость_стола_подготовки: Integer
    +добавить_пиццу(пицца: Пицца, минуты: Integer): Integer
    +тик(минуты: Integer): List<Integer>
}

class Терминал_карты {
    -работает: Boolean
    -подключен: Boolean
    -есть_бумага: Boolean
    +может_обработать(): Boolean
}

class Касса {
    -наличные: Float
    -есть_бумага: Boolean
}

class Система_оплаты {
    -терминал: Терминал_карты
    -касса: Касса
    +обработать(сумма: Float, тип: String): void
}

class Стойка_заказов {
    -меню: Меню
    -система_оплаты: Система_оплаты
}

class Задача_доставки {
    -id_заказа: Integer
    -оставшееся_время: Integer
}

class Координатор_доставки {
    -задачи: Map<Integer, Задача_доставки>
    +начать(id_заказа: Integer, минуты: Integer): void
    +тик(минуты: Integer): List<Integer>
}

class Пиццерия {
    -кухня: Кухня
    -зал: Зал
    -стойка: Стойка_заказов
    -доставка: Координатор_доставки
    -сотрудники: List<Сотрудник>
    -заказы: List<Заказ>
    -следующий_id_заказа: Integer
    -следующий_id_пиццы: Integer
    -выручка: Float
    -чаевые: Float
}

' ==================== ПРИЛОЖЕНИЕ ====================

class Сервис_пиццерии {
    -пиццерия: Пиццерия
    +создать_заказ_в_зале(): Заказ
    +создать_заказ_с_доставкой(): Заказ
    +подтвердить_заказ(id: Integer): Заказ
    +отправить_на_кухню(id: Integer): Заказ
    +начать_доставку(id: Integer): Заказ
    +оплатить_заказ(id: Integer): Заказ
    +завершить_заказ(id: Integer): Заказ
    +отменить_заказ(id: Integer): Заказ
}

' ==================== ИНФРАСТРУКТУРА ====================

class Json_репозиторий {
    -путь: Path
    +загрузить(): Пиццерия
    +сохранить(пиццерия: Пиццерия): void
}

' ==================== ИНТЕРФЕЙС ====================

class CLI_приложение {
    -сервис: Сервис_пиццерии
    +запустить(): void
}

' ==================== СВЯЗИ ====================

Меню "1" *-- "0..*" Пункт_меню
Заказ "1" *-- "1..*" Пицца
Заказ "1" *-- "0..*" Пункт_меню
Заказ --> Клиент

Зал "1" *-- "0..*" Стол

Кухня "1" *-- "1..*" Печь
Кухня "1" *-- "1" Склад
Печь "1" *-- "0..*" Задача_выпечки

Система_оплаты "1" *-- "1" Терминал_карты
Система_оплаты "1" *-- "1" Касса

Стойка_заказов "1" *-- "1" Меню
Стойка_заказов "1" *-- "1" Система_оплаты

Координатор_доставки "1" *-- "0..*" Задача_доставки

Пиццерия "1" *-- "1" Кухня
Пиццерия "1" *-- "1" Зал
Пиццерия "1" *-- "1" Стойка_заказов
Пиццерия "1" *-- "1" Координатор_доставки
Пиццерия "1" *-- "*" Сотрудник
Пиццерия "1" *-- "0..*" Заказ

Сервис_пиццерии --> Пиццерия
Json_репозиторий --> Пиццерия
CLI_приложение --> Сервис_пиццерии

@enduml2